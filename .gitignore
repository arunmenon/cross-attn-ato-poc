# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenv
.venv/

# Data + checkpoints (large, RunPod-side only)
data/train_llm_narrated/
data/eval_fast_5k/
data/eval_medium_50k/
data/eval_large/
data/samples/
# LLM-narrator response cache. Hash-keyed by structured-stream content;
# re-running build_dataset is free once these are populated. Optional to
# upload alongside the dataset to give the pod a resumable cache.
data/cache/
checkpoints/

# Auto-research runtime artifacts
# Track configs, logs, metrics, predictions, CI reports, gate trajectories,
# clean-eval masks, notes — everything small enough to commit. Skip the
# binary model checkpoints (200-400 MB each per x-attn run).
*.gpu.lock
src/auto_research/runs/**/*.pt
src/auto_research/runs/**/*.safetensors
src/auto_research/runs/**/*.bin
src/auto_research/runs/**/*.ckpt
src/auto_research/runs/**/checkpoint-*/    # HF Trainer checkpoint subdirs
# PEFT LoRA adapter + tokenizer dirs (regenerable from base + LoRA spec).
# Use file-level patterns since `**/dir/` exclusions don't match reliably here.
src/auto_research/runs/**/tokenizer.json
src/auto_research/runs/**/tokenizer_config.json
src/auto_research/runs/**/vocab.json
src/auto_research/runs/**/merges.txt
src/auto_research/runs/**/special_tokens_map.json
src/auto_research/runs/**/added_tokens.json
src/auto_research/runs/**/adapter_model.safetensors
src/auto_research/runs/**/adapter_model.bin
src/auto_research/runs/**/chat_template.jinja
# Auto-research training state (.pt etc.) is regenerated by the trainer;
# rerun cost is bounded. Predictions / metrics / CI are the durable
# artifacts and must be checked in for reproducibility of the leaderboard.

# Wandb
.wandb/
wandb/

# Build / temp logs
build_dataset_*.log
preflight_*.log

# OS
.DS_Store

# Editor
.vscode/
.idea/
